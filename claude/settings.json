{
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "200000",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(which *)",
      "Bash(rg *)",
      "Bash(fdfind *)",
      "Bash(fd *)"
    ]
  },
  "model": "opusplan",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOME}/.claude/hooks/genshijin-activate.js\"",
            "statusMessage": "原始人モード読込中..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HOME}/.claude/hooks/genshijin-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "原始人モード追跡中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "language": "japanese",
  "effortLevel": "high",
  "autoCompactWindow": 200000,
  "theme": "dark",
  "verbose": false,
  "autoCompact": true,
  "compactTrigger": 0.6
}
